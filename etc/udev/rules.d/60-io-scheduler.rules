# ============================================================================
# Kiro-ISO I/O Scheduler Rules - Auto-optimize by device type
# ============================================================================
# Automatically selects optimal I/O scheduler based on storage device
# Applies on device detection (boot + hotplug)

# NVMe devices: minimal overhead (none scheduler)
ACTION=="add|change", KERNEL=="nvme[0-9]*n[0-9]*", ATTR{queue/scheduler}="none"

# SSD (non-rotating): fair I/O distribution
ACTION=="add|change", KERNEL=="sd[a-z]*|mmcblk[0-9]*", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="bfq"

# HDD (mechanical, rotating): optimize seek patterns
ACTION=="add|change", KERNEL=="sd[a-z]*", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="mq-deadline"

# Virtual disks: no scheduling needed
ACTION=="add|change", KERNEL=="vd[a-z]*", ATTR{queue/scheduler}="none"

# USB/External: safe default
ACTION=="add|change", KERNEL=="sd[a-z]*", SUBSYSTEMS=="usb", ATTR{queue/scheduler}="mq-deadline"
