#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

main() {
    log_warn "Some commands will give no output or error messages — one of them should give you info"

    log_section "Check 1 — lspci"
    echo "command 1:"
    lspci -vnnn | perl -lne 'print if /^\d+\:.+(\[\S+\:\S+\])/' | grep VGA
    echo
    echo "command 2:"
    lspci -x | grep VGA

    log_section "Check 2 — glxinfo"
    if test -f /usr/bin/glxinfo ; then
        log_info "glxinfo is present"
    else
        log_info "Installing glxinfo (note: conflicts with mesa-demos)"
        sudo pacman -S glxinfo --noconfirm
    fi
    glxinfo | grep -E "OpenGL vendor|OpenGL renderer*"

    log_section "Check 3 — nvidia-smi"
    if test -f /usr/bin/nvidia-smi; then
        nvidia-smi -L
    else
        log_info "No nvidia driver present"
    fi

    log_success "$(basename "$0") done"
}

main "$@"
