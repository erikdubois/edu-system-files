#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -Euo pipefail

# Source common library
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

##################################################################################################################
# Author 	: Erik Dubois
# Website   : https://www.erikdubois.be
# Website   : https://www.alci.online
# Website	: https://www.arcolinux.info
# Website	: https://www.arcolinux.com
# Website	: https://www.arcolinuxd.com
# Website	: https://www.arcolinuxb.com
# Website	: https://www.arcolinuxiso.com
# Website	: https://www.arcolinuxforum.com
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################

# Parse common arguments
parse_common_args "edu-fix-pacman-databases-and-keys" "1.0.0" \
    "Fix pacman database and GPG key issues" \
    "[OPTIONS]" \
    "    (no additional options)" \
    "$@"
#tput setaf 0 = black 
#tput setaf 1 = red 
#tput setaf 2 = green
#tput setaf 3 = yellow 
#tput setaf 4 = dark blue 
#tput setaf 5 = purple
#tput setaf 6 = cyan 
#tput setaf 7 = gray 
#tput setaf 8 = light blue
##################################################################################################################

Online=0

if check_connectivity 3 8.8.8.8; then
	Online=1
else
	Online=0
fi

if [[ "${Online}" -eq 1 ]]; then
	log_subsection "Installing the latest archlinux-keyring package"
	sudo pacman -Sy archlinux-keyring --noconfirm || log_warn "Failed to install archlinux-keyring"
fi

log_section "Fixing pacman database and GPG configuration"

# Confirm before proceeding
if ! confirm_destructive_operation "fix pacman database and GPG keys"; then
	log_warn "Operation cancelled"
	exit 0
fi

log_subsection "Removing pacman sync databases"
if [[ -d /var/lib/pacman/sync ]]; then
	sudo rm -f /var/lib/pacman/sync/*.db /var/lib/pacman/sync/*.db.sig || log_warn "Failed to remove all sync databases"
else
	log_info "Directory not found: /var/lib/pacman/sync"
fi

log_subsection "Removing pacman GPG keys"
if [[ -d /etc/pacman.d/gnupg ]]; then
	sudo rm -rf /etc/pacman.d/gnupg/* || log_warn "Failed to remove GPG keys"
else
	log_info "Directory not found: /etc/pacman.d/gnupg"
fi

log_subsection "Initializing pacman keys"
sudo pacman-key --init || log_warn "Failed to initialize pacman keys"

log_subsection "Populating keyring"
sudo pacman-key --populate || log_warn "Failed to populate keyring"

log_subsection "Adding Ubuntu keyserver to gpg.conf"
if [[ -f /etc/pacman.d/gnupg/gpg.conf ]]; then
	echo "keyserver hkp://keyserver.ubuntu.com:80" | sudo tee -a /etc/pacman.d/gnupg/gpg.conf >/dev/null
else
	log_warn "File not found: /etc/pacman.d/gnupg/gpg.conf"
fi

log_subsection "Refreshing pacman databases"
sudo pacman -Sy || log_warn "Failed to refresh pacman databases"

log_success "Pacman database and GPG configuration fixed"