#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

main() {
    log_section "Copying /etc/pacman.d/gnupg/gpg.conf"

    local gpg_conf="/usr/local/share/kiro/gpg.conf"
    if [[ -f "$gpg_conf" ]]; then
        log_info "$gpg_conf exists"
        sudo cp "$gpg_conf" /etc/pacman.d/gnupg/gpg.conf
        log_success "/etc/pacman.d/gnupg/gpg.conf copied from local system"
    else
        log_warn "$gpg_conf not found — skipping"
    fi

    log_success "$(basename "$0") done"
}

main "$@"
