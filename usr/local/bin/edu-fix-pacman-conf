#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -Euo pipefail

# Source common library
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
# Website   : https://www.alci.online
# Website   : https://www.arcolinux.info
# Website   : https://www.arcolinux.com
# Website   : https://www.arcolinuxd.com
# Website   : https://www.arcolinuxb.com
# Website   : https://www.arcolinuxiso.com
# Website   : https://www.arcolinuxforum.com
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################
#tput setaf 0 = black 
#tput setaf 1 = red 
#tput setaf 2 = green
#tput setaf 3 = yellow 
#tput setaf 4 = dark blue 
#tput setaf 5 = purple
#tput setaf 6 = cyan 
#tput setaf 7 = gray 
#tput setaf 8 = light blue
##################################################################################################################

log_section "Getting latest /etc/pacman.conf"

Online=0
file_boolean=0

function check_connectivity() {

    local test_ip
    local test_count

    test_ip="8.8.8.8"
    test_count=1

    if ping -c ${test_count} ${test_ip} > /dev/null; then
       echo "You have internet connectivity"
       Online=1
    else
       echo "You do not have connectivity"
       Online=0
    fi
 }

function check_file() {

	local file="/usr/local/share/edu/pacman.conf"
	if [[ -f "${file}" ]]; then
    	log_success "File exists: ${file}"
    	file_boolean=1
	else
    	log_info "File not found: ${file}"
    	file_boolean=0
	fi
}

check_connectivity
check_file


# pacman config + online
if [[ "${Online}" -eq 1 ]]; then
	log_subsection "Downloading latest /etc/pacman.conf from github"
	if sudo wget https://raw.githubusercontent.com/erikdubois/arcolinux-nemesis/refs/heads/master/pacman.conf -O /etc/pacman.conf; then
		log_success "pacman.conf downloaded successfully"
	else
		log_warn "Failed to download pacman.conf"
		return 1
	fi
fi

# pacman config + not online
if [[ "${Online}" -eq 0 ]] && [[ "${file_boolean}" -eq 1 ]]; then
	log_subsection "Using local pacman.conf"
	sudo cp /usr/local/share/edu/pacman.conf /etc/pacman.conf || {
		log_warn "Failed to copy pacman.conf"
		return 1
	}
	log_success "pacman.conf saved from local system"
fi

# No local or online config available
if [[ "${Online}" -eq 0 ]] && [[ "${file_boolean}" -eq 0 ]]; then
	log_warn "No configuration available. Run this script once you are back online."
	return 1
fi

log_success "Script completed successfully"
