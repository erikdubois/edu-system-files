#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://www.erikdubois.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################

# shellcheck source=/usr/local/lib/kiro-common.sh
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

main() {
    sudo pacman -Syy
    sudo pacman -S sublime-text-4 --noconfirm --needed
    sudo pacman -S ripgrep --noconfirm --needed
    sudo pacman -S meld --noconfirm --needed
    sudo pacman -S thunar --noconfirm --needed
    sudo pacman -S thunar-archive-plugin --noconfirm --needed
    sudo pacman -S thunar-volman --noconfirm --needed
    log_success "$(basename "$0") done"
}

main "$@"
