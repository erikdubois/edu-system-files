#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -Euo pipefail

# Source common library
if [[ -f /usr/local/lib/kiro-common.sh ]]; then
    source /usr/local/lib/kiro-common.sh
else
    echo "ERROR: kiro-common.sh not found" >&2
    exit 1
fi

##################################################################################################################
# Author 	: Erik Dubois
# Website   : https://www.erikdubois.be
# Website   : https://www.alci.online
# Website	: https://www.arcolinux.info
# Website	: https://www.arcolinux.com
# Website	: https://www.arcolinuxd.com
# Website	: https://www.arcolinuxb.com
# Website	: https://www.arcolinuxiso.com
# Website	: https://www.arcolinuxforum.com
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
##################################################################################################################
#tput setaf 0 = black 
#tput setaf 1 = red 
#tput setaf 2 = green
#tput setaf 3 = yellow 
#tput setaf 4 = dark blue 
#tput setaf 5 = purple
#tput setaf 6 = cyan 
#tput setaf 7 = gray 
#tput setaf 8 = light blue
##################################################################################################################

#iso=arconet-kiro

log_section "Cloning linux-kiro repository"

if ! command -v git &>/dev/null; then
	log_subsection "Installing git"
	sudo pacman -S git --noconfirm || {
		log_warn "Failed to install git"
		exit 1
	}
else
	log_success "git is already installed"
fi

# Create and navigate to data directory
mkdir -p "${HOME}/DATA" || {
	log_warn "Failed to create directory: ${HOME}/DATA"
	exit 1
}

cd "${HOME}/DATA" || {
	log_warn "Failed to change to directory: ${HOME}/DATA"
	exit 1
}

log_subsection "Cloning linux-kiro repository"
if git clone https://github.com/kirodubes/linux-kiro; then
	log_success "Repository cloned successfully"
else
	log_warn "Failed to clone repository"
	exit 1
fi

log_success "linux-kiro repository cloned successfully"
